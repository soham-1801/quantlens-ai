# Database configuration (Defaults to SQLite, set PostgreSQL for production)
DATABASE_URL=sqlite:///./quantlens.db

# JWT Configuration: Change this to a long random string in production
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Finnhub API (free tier: 60 calls/min, register at https://finnhub.io)
FINNHUB_API_KEY=

# CORS — comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,https://quantlens-ai.vercel.app
